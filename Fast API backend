from fastapi import FastAPI
from pydantic import BaseModel

app = FastAPI(title="AI-First CRM HCP Module")

# Request Models
class Interaction(BaseModel):
    hcp_name: str
    hospital: str
    meeting_date: str
    meeting_type: str
    products: str
    summary: str
    follow_up: str
    notes: str

class ChatRequest(BaseModel):
    message: str

# Home API
@app.get("/")
def home():
    return {"message": "AI-First CRM Backend Running"}

# Log Interaction
@app.post("/interaction")
def log_interaction(interaction: Interaction):
    # TODO: Save to database
    return {
        "status": "success",
        "message": "Interaction logged successfully",
        "data": interaction
    }

# AI Chat
@app.post("/chat")
def chat(request: ChatRequest):
    # TODO: Send to LangGraph + Groq
    return {
        "user_message": request.message,
        "ai_response": "This will be generated by LangGraph + Groq."
    }

# Edit Interaction
@app.put("/interaction/{interaction_id}")
def edit_interaction(interaction_id: int, interaction: Interaction):
    # TODO: Update database
    return {
        "status": "updated",
        "interaction_id": interaction_id,
        "data": interaction
    }

# Get All Interactions
@app.get("/interactions")
def get_interactions():
    # TODO: Fetch from database
    return {"interactions": []}

# Get Interaction History
@app.get("/history/{hcp_id}")
def get_history(hcp_id: int):
    # TODO: Fetch history from database
    return {
        "hcp_id": hcp_id,
        "history": []
    }